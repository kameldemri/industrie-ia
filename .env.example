# ==========================================
# LLM CONFIGURATION (CHOOSE ONE MODE)
# ==========================================

# MODE 1: LOCAL OLLAMA (Default, free, no API key)
LLM_BASE_URL=http://ollama:11434/v1
LLM_API_KEY=unused
LLM_MODEL_NAME=mistral

# MODE 2: FREE EXTERNAL API (e.g., Qwen via OpenRouter)
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=sk-or-v1-...  # Get free at openrouter.ai
# LLM_MODEL_NAME=qwen/qwen-2.5-7b-instruct:free

# App Config
FASTAPI_ENV=development
